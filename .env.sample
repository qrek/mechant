CLIENT_BASIC_AUTH_USER=XXXXXXXXXX
CLIENT_BASIC_AUTH_PASSWORD=XXXXXXXXXX

# Supabase — récupérer sur app.supabase.com > Settings > API
SUPABASE_URL=https://XXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=XXXXXXXXXX

# Service role key — uniquement pour le script de migration, jamais sur Vercel
SUPABASE_SERVICE_KEY=XXXXXXXXXX

# Cloudflare R2 — storage des preview videos (egress gratuite)
# Récupérer sur dash.cloudflare.com > R2 > Overview (Account Details panel)
# et R2 > Manage API Tokens
R2_ACCOUNT_ID=XXXXXXXXXX
R2_ACCESS_KEY_ID=XXXXXXXXXX
R2_SECRET_ACCESS_KEY=XXXXXXXXXX
R2_ENDPOINT=https://XXXXXXXXXX.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-XXXXXXXXXX.r2.dev
R2_BUCKET_NAME=mechant-previews
